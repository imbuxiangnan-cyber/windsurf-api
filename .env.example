# 服务端口
PORT=4000

# API 密钥（留空则不验证）
API_KEY=

# Dashboard 密码
DASHBOARD_PASSWORD=

# Language Server 二进制路径（留空则自动检测）
LS_BINARY_PATH=

# Language Server 端口
LS_PORT=42100

# Windsurf API 服务器
API_SERVER_URL=https://server.self-serve.windsurf.com

# 默认模型
DEFAULT_MODEL=claude-sonnet-4.6

# 最大 token 数
MAX_TOKENS=8192

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 数据目录
DATA_DIR=./data
